# ========================================
# A.N.N. (AI News Network) - Environment
# ========================================

# --- LLM Brain ---
# Option 1: OpenAI
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# Option 2: Google Gemini (FREE! 15 RPM)
# LLM_API_KEY=your-gemini-api-key
# LLM_MODEL=gemini-2.0-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# --- News Ingestion ---
NEWS_API_KEY=your_newsapi_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# --- Media Production ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_EN=your_english_voice_id
ELEVENLABS_VOICE_HI=your_hindi_voice_id

HEYGEN_API_KEY=your_heygen_api_key_here
HEYGEN_AVATAR_EN=your_english_avatar_id
HEYGEN_AVATAR_HI=your_hindi_avatar_id

# --- Social Media (optional — auto-post to platforms) ---
TWITTER_BEARER_TOKEN=
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
SOCIAL_AUTO_POST=false

# --- Server Config ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
PUBLIC_URL=http://localhost:8000
